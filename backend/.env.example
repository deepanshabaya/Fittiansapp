# ─── Server ────────────────────────────────────────────
# Local dev only. On Railway, PORT is injected automatically — do NOT set it.
PORT=3000
NODE_ENV=development

# ─── Database ──────────────────────────────────────────
# Production (Railway): set DATABASE_URL from the Postgres plugin.
# Railway gives you a reference like ${{Postgres.DATABASE_URL}}.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# SSL is enabled automatically when DATABASE_URL is set.
# Only set DB_SSL=false if connecting over a private network without TLS.
# DB_SSL=false

# Local dev (used only when DATABASE_URL is NOT set)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fitnessapp
DB_PORT=5432

# ─── Auth ──────────────────────────────────────────────
# REQUIRED. Generate a strong random value (e.g. `openssl rand -hex 32`).
# Never commit the real secret — set it in the Railway dashboard.
JWT_SECRET=change-me-to-a-long-random-string
